   "source": [
    "# Sprint 1–2 notebook\n",
    "Quick runs for defect curves. Source of truth stays in docs/sprint-01-02.md. Timestamped outputs are saved automatically."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from pathlib import Path\n",
    "from dashi.baseline.residuals import compute_residuals\n",
    "from dashi.io.hemibrain_loader import load_edge_list\n",
    "from dashi.kernel.flow import kernel_flow\n",
    "from dashi.types import GraphCarrier, KernelParams\n",
    "from dashi.valuation.init_field import init_field_from_residual\n",
    "from scripts.defect_curve import save_defect_csv, save_defect_plot, timestamp\n",
    "\n",
    "edges = Path('path/to/edges.csv')  # TODO: set real path\n",
    "metadata = None  # optionally set\n",
    "deadzone = 1e-9\n",
    "hops = 1\n",
    "steps = 20\n",
    "out_prefix = Path('outputs/notebook_defect')\n",
    "\n",
    "hb = load_edge_list(str(edges), metadata_path=metadata)\n",
    "residual, balance = compute_residuals(hb.carrier.adjacency, deadzone=deadzone)\n",
    "s0 = init_field_from_residual(residual, deadzone=deadzone)\n",
    "params = KernelParams(hops=hops, deadzone=deadzone)\n",
    "carrier = GraphCarrier(adjacency=hb.carrier.adjacency, channels=hb.carrier.channels)\n",
    "final, history, status = kernel_flow(carrier, s0, params, steps=steps)\n",
    "\n",
    "print(f'Balance: {balance}')\n",
    "print(f'Status: {status}')\n",
    "for h in history:\n",
    "    print(f"{h['step']}: {h['defect']}")\n",
    "\n",
    "ts = timestamp()\n",
    "csv_path = out_prefix.parent / f"{out_prefix.name}_{ts}.csv"\n",
    "png_path = out_prefix.parent / f"{out_prefix.name}_{ts}.png"\n",
    "save_defect_csv(str(csv_path), history)\n",
    "save_defect_plot(str(png_path), history)\n",
    "csv_path, png_path\n"
   ]
  }
 ],
