def build_initial_ternary_state_from_residuals(residual_A: sp.csr_matrix, deadzone: float) -> np.ndarray:
    # simplest single-channel: sign of row-sum residual as node-state
    node_res = np.asarray(residual_A.sum(axis=1)).reshape(-1)
    return sgn_deadzone(node_res, deadzone)[:, None]

def coarse_grain_blocks(s: np.ndarray, blocks: np.ndarray) -> np.ndarray:
    """
    blocks: int array of length N mapping node -> block id in [0..B-1]
    returns: s_coarse shape (B,C) via sum then sgn (your R_j rule)
    """
    N, C = s.shape
    B = int(blocks.max()) + 1
    out = np.zeros((B, C), dtype=np.float32)
    for c in range(C):
        np.add.at(out[:, c], blocks, s[:, c].astype(np.float32))
    return sgn_deadzone(out, 0.0).astype(T)

